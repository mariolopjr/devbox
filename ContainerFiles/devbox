FROM quay.io/fedora/fedora-toolbox:latest

LABEL com.github.containers.toolbox="true" \
      usage="This image is meant to be used with the toolbox or distrobox command" \
      summary="A cloud-native terminal experience" \
      maintainer="mario@techmunchies.net"

# Copy the setup scripts and package list
COPY ../scripts/devbox.sh /
COPY ../scripts/distrobox-shims.sh /
COPY ../packages/devbox.packages /

# ublue staging repo needed for ghostty, etc
dnf -y copr enable ublue-os/staging

# common packages installed to desktops
dnf install -y \
	ublue-brew

# only the packages above should come from testing
dnf -y copr disable ublue-os/staging

# Run the setup scripts
RUN /devbox.sh
RUN rm /devbox.sh /distrobox-shims.sh /devbox.packages
